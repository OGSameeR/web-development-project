# html code
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Naye Pankh Foundation | Empowering Lives</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

    <nav class="navbar">
        <div class="nav-container">
            <a href="#home" class="logo"><i class="fa-solid fa-dove"></i> Naye Pankh</a>
            <ul class="nav-links" id="navLinks">
                <li><a href="#home" class="active">Home</a></li>
                <li><a href="#about">About Us</a></li>
                <li><a href="#impact">Our Impact</a></li>
                <li><a href="#contact">Contact</a></li>
                <li><a href="#donate" class="btn-donate-nav">Donate Now</a></li>
            </ul>
            <div class="menu-toggle" id="mobileMenu">
                <i class="fa-solid fa-bars"></i>
            </div>
        </div>
    </nav>

    <section id="home" class="hero">
        <div class="hero-content">
            <h1>Giving Wings to <span class="highlight">Their Dreams</span></h1>
            <p>Join Naye Pankh Foundation in providing education, healthcare, and sustainable livelihood to underprivileged communities.</p>
            <div class="hero-buttons">
                <a href="#about" class="btn-primary">Learn More</a>
                <a href="#donate" class="btn-secondary">Support Our Cause</a>
            </div>
        </div>
    </section>

    <section id="about" class="about">
        <div class="container">
            <h2 class="section-title">Who We Are</h2>
            <div class="about-grid">
                <div class="about-text">
                    <h3>Spreading Hope, Changing Lives</h3>
                    <p>Naye Pankh Foundation is a non-profit organization dedicated to uplifting the marginalized sections of society. We believe that every individual deserves the opportunity to fly high and achieve their full potential.</p>
                    <p>Through our dedicated volunteer network, we run regular food drives, educational camps, and women empowerment workshops across communities.</p>
                </div>
                <div class="about-cards">
                    <div class="card fade-in">
                        <i class="fa-solid fa-graduation-cap card-icon"></i>
                        <h4>Education</h4>
                        <p>Providing basic schooling and digital literacy to children.</p>
                    </div>
                    <div class="card fade-in">
                        <i class="fa-solid fa-bowl-food card-icon"></i>
                        <h4>Nutrition</h4>
                        <p>Distributing healthy meals to battle malnutrition.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="impact" class="impact">
        <div class="container">
            <h2 class="section-title text-white">Our Impact So Far</h2>
            <div class="stats-grid">
                <div class="stat-item">
                    <h3 class="stat-number">10k+</h3>
                    <p>Lives Impacted</p>
                </div>
                <div class="stat-item">
                    <h3 class="stat-number">50+</h3>
                    <p>Villages Reached</p>
                </div>
                <div class="stat-item">
                    <h3 class="stat-number">500+</h3>
                    <p>Active Volunteers</p>
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="contact-donate">
        <div class="container">
            <div class="form-grid">
                <div class="contact-form" id="contact">
                    <h3>Get In Touch</h3>
                    <form>
                        <input type="text" placeholder="Your Name" required>
                        <input type="email" placeholder="Your Email" required>
                        <textarea placeholder="Your Message" rows="5" required></textarea>
                        <button type="submit" class="btn-primary">Send Message</button>
                    </form>
                </div>
                <div class="donate-box" id="donate">
                    <h3>Make a Difference</h3>
                    <p>Your small contribution can provide food, clothing, and education to someone in desperate need.</p>
                    <div class="amount-buttons">
                        <button class="btn-amount">$10</button>
                        <button class="btn-amount active-amt">$25</button>
                        <button class="btn-amount">$50</button>
                    </div>
                    <button class="btn-donate-large">Proceed to Donate <i class="fa-solid fa-heart"></i></button>
                </div>
            </div>
        </div>
    </section>

    <footer>
        <p>&copy; 2026 Naye Pankh Foundation. All Rights Reserved.</p>
        <div class="social-icons">
            <a href="#"><i class="fa-brands fa-facebook"></i></a>
            <a href="#"><i class="fa-brands fa-instagram"></i></a>
            <a href="#"><i class="fa-brands fa-twitter"></i></a>
        </div>
    </footer>

    <script src="/script.js"></script>
</body>
</html>
